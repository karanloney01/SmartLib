generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Auth {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  fullName  String
  role      Role
  profile   Profile?
  student   Student?
  librarian Librarian?
}

enum Role {
  STUDENT
  LIBRARIAN
  ADMIN
}

model Profile {
  id        Int     @id
  auth      Auth    @relation(fields: [id], references: [id], onDelete: Cascade)
  role      Role
  completed Boolean @default(false)
}

model Student {
  studentId    Int           @id @default(autoincrement())
  authId       Int           @unique
  auth         Auth          @relation(fields: [authId], references: [id], onDelete: Cascade)
  issues       Issue[]
  fines        Fine[]
  reservations Reservation[]
}

model Librarian {
  librarianId   Int    @id @default(autoincrement())
  authId        Int    @unique
  auth          Auth   @relation(fields: [authId], references: [id], onDelete: Cascade)
  librarianName String
  books         Book[]
}

model Author {
  authorId Int    @id @default(autoincrement())
  name     String
  books    Book[]
}

model Category {
  categoryId Int    @id @default(autoincrement())
  name       String @unique
  books      Book[]
}

model Publisher {
  publisherId Int    @id @default(autoincrement())
  name        String
  books       Book[]
}

model Book {
  bookId        Int     @id @default(autoincrement())
  title         String
  isbn          String? @unique
  publishedYear Int?

  authorId Int?
  author   Author? @relation(fields: [authorId], references: [authorId], onDelete: SetNull)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [categoryId], onDelete: SetNull)

  publisherId Int?
  publisher   Publisher? @relation(fields: [publisherId], references: [publisherId], onDelete: SetNull)

  librarianId Int?
  librarian   Librarian? @relation(fields: [librarianId], references: [librarianId], onDelete: SetNull)

  copies       BookCopy[]
  reservations Reservation[]
}

enum CopyStatus {
  AVAILABLE
  ISSUED
  LOST
  DAMAGED
}

model BookCopy {
  copyId        Int        @id @default(autoincrement())
  bookId        Int
  book          Book       @relation(fields: [bookId], references: [bookId], onDelete: Cascade)
  status        CopyStatus @default(AVAILABLE)
  shelfLocation String?
  issues        Issue[]
}

model Issue {
  issueId    Int       @id @default(autoincrement())
  studentId  Int
  copyId     Int
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  student    Student   @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  copy       BookCopy  @relation(fields: [copyId], references: [copyId], onDelete: Cascade)
  fine       Fine?
}

model Fine {
  fineId    Int       @id @default(autoincrement())
  issueId   Int       @unique
  issue     Issue     @relation(fields: [issueId], references: [issueId], onDelete: Cascade)
  studentId Int
  student   Student   @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  amount    Decimal   @db.Decimal(10, 2)
  isPaid    Boolean   @default(false)
  paidDate  DateTime?
}

enum ReservationStatus {
  PENDING
  FULFILLED
  CANCELLED
}

model Reservation {
  reservationId   Int               @id @default(autoincrement())
  studentId       Int
  bookId          Int
  reservationDate DateTime          @default(now())
  status          ReservationStatus @default(PENDING)
  student         Student           @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  book            Book              @relation(fields: [bookId], references: [bookId], onDelete: Cascade)
}
